              }
            ],
            "styles": [
              "projects/shared-ui/src/lib/theme/colors.css",
              "projects/tic-tac-toe/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "tic-tac-toe:build:production"
            },
            "development": {
              "buildTarget": "tic-tac-toe:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "snake": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/snake",
      "sourceRoot": "projects/snake/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/snake/src/main.ts",
            "tsConfig": "projects/snake/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
